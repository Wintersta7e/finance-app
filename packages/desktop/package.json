{
  "name": "@finance/desktop",
  "private": true,
  "version": "1.1.0",
  "description": "Finance desktop app with embedded backend",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=development electron ./electron/main.js",
    "electron:prod": "cross-env NODE_ENV=production electron ./electron/main.js",
    "build:backend": "bash ../backend/scripts/prepare-production.sh",
    "build:desktop": "npm run build:backend && npm run build && electron-builder",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "framer-motion": "^12.35.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "rooty.finance.desktop",
    "productName": "Finance Desktop",
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/node_modules_prod",
        "to": "backend/node_modules"
      },
      {
        "from": "../backend/prisma",
        "to": "backend/prisma",
        "filter": [
          "schema.prisma",
          "migrations/**/*",
          "migration_lock.toml"
        ]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Finance Desktop-${version}-portable.${ext}"
    }
  }
}
